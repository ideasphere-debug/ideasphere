<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IdeaSphere — Global Community Ideas Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,600;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --ink:#111209;
  --ink2:#3a3a2e;
  --muted:#7a7a65;
  --cream:#f8f5ef;
  --white:#ffffff;
  --border:rgba(17,18,9,0.1);
  --border2:rgba(17,18,9,0.18);
  --green:#1f6b43;
  --green-l:#2e9460;
  --green-bg:#e8f4ec;
  --green-bg2:#c8e8d4;
  --blue:#1a5080;
  --blue-bg:#e4eff8;
  --red:#b83030;
  --red-bg:#faeaea;
  --amber:#9a6010;
  --amber-bg:#fdf3de;
  --purple:#5a2d8a;
  --purple-bg:#f0e8fa;
  --teal:#0d6e6e;
  --teal-bg:#e0f2f2;
  --r:10px;
  --r2:16px;
  --shadow:0 2px 16px rgba(17,18,9,0.07);
  --shadow2:0 6px 32px rgba(17,18,9,0.12);
}

html{scroll-behavior:smooth}
body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--cream);color:var(--ink);line-height:1.6;min-height:100vh}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:var(--cream)}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}

/* ── NAVBAR ── */
.nav{
  position:sticky;top:0;z-index:50;
  background:var(--ink);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 2rem;height:58px;
}
.logo{
  font-family:'Fraunces',serif;font-size:1.35rem;font-weight:700;color:#fff;
  display:flex;align-items:center;gap:8px;text-decoration:none;
  letter-spacing:-0.5px;
}
.logo-dot{
  width:28px;height:28px;border-radius:50%;
  background:linear-gradient(135deg,var(--green-l),#5ecf8a);
  display:flex;align-items:center;justify-content:center;
  font-size:0.8rem;flex-shrink:0;
}
.nav-right{display:flex;align-items:center;gap:1.5rem}
.nav-link{color:rgba(255,255,255,0.65);font-size:0.88rem;font-weight:400;cursor:pointer;border:none;background:none;font-family:'Plus Jakarta Sans',sans-serif;transition:color 0.2s}
.nav-link:hover{color:#fff}
.nav-btn{
  background:var(--green-l);color:#fff;border:none;
  padding:7px 16px;border-radius:20px;font-size:0.85rem;font-weight:600;
  cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;transition:background 0.2s;
}
.nav-btn:hover{background:var(--green)}

/* ── HERO ── */
.hero{
  background:var(--ink);color:#fff;
  padding:4.5rem 2rem 3.5rem;text-align:center;
  position:relative;overflow:hidden;
}
.hero-bg{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 60% 80% at 20% 60%,rgba(46,148,96,0.13) 0%,transparent 70%),
    radial-gradient(ellipse 50% 70% at 80% 30%,rgba(26,80,128,0.1) 0%,transparent 70%),
    radial-gradient(ellipse 40% 50% at 50% 100%,rgba(90,45,138,0.08) 0%,transparent 70%);
  pointer-events:none;
}
.hero-inner{position:relative;max-width:700px;margin:0 auto}
.hero-pill{
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);
  color:rgba(255,255,255,0.85);font-size:0.78rem;font-weight:500;
  padding:5px 14px;border-radius:20px;margin-bottom:1.5rem;letter-spacing:0.3px;
}
.hero h1{
  font-family:'Fraunces',serif;font-size:clamp(2rem,5vw,3.2rem);
  font-weight:700;line-height:1.12;letter-spacing:-1.5px;margin-bottom:1.1rem;
}
.hero h1 em{color:#6ee89c;font-style:italic}
.hero-sub{
  font-size:1rem;color:rgba(255,255,255,0.6);font-weight:300;
  max-width:480px;margin:0 auto 2.2rem;
}
.hero-cta{display:flex;gap:0.8rem;justify-content:center;flex-wrap:wrap}
.btn-hero-p{
  background:var(--green-l);color:#fff;border:none;
  padding:12px 26px;border-radius:8px;font-size:0.95rem;font-weight:600;
  cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;transition:all 0.2s;
}
.btn-hero-p:hover{background:var(--green);transform:translateY(-1px)}
.btn-hero-s{
  background:transparent;color:rgba(255,255,255,0.75);
  border:1px solid rgba(255,255,255,0.22);
  padding:12px 26px;border-radius:8px;font-size:0.95rem;
  cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;transition:all 0.2s;
}
.btn-hero-s:hover{border-color:rgba(255,255,255,0.5);color:#fff}

/* ── STATS BAR ── */
.stats-bar{
  background:var(--white);border-bottom:1px solid var(--border);
  display:flex;justify-content:center;align-items:center;
  gap:0;flex-wrap:wrap;
}
.stat-item{
  padding:1.1rem 2.2rem;text-align:center;
  border-right:1px solid var(--border);
}
.stat-item:last-child{border-right:none}
.stat-n{font-family:'Fraunces',serif;font-size:1.6rem;font-weight:700;color:var(--green);line-height:1}
.stat-l{font-size:0.72rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.6px;margin-top:2px}

/* ── MAIN ── */
.page{max-width:1200px;margin:0 auto;padding:2.5rem 1.5rem}
.layout{display:grid;grid-template-columns:1fr 310px;gap:2rem;align-items:start}
@media(max-width:900px){.layout{grid-template-columns:1fr}.sidebar{order:-1}}

/* ── SEARCH ── */
.search-row{display:flex;gap:0.75rem;margin-bottom:1.5rem;flex-wrap:wrap}
.search-wrap{position:relative;flex:1;min-width:200px}
.search-icon{position:absolute;left:13px;top:50%;transform:translateY(-50%);color:var(--muted);pointer-events:none;font-size:1rem}
.search-input{
  width:100%;padding:10px 14px 10px 38px;
  border:1px solid var(--border2);border-radius:8px;
  font-family:'Plus Jakarta Sans',sans-serif;font-size:0.9rem;
  background:var(--white);color:var(--ink);outline:none;transition:border-color 0.2s;
}
.search-input:focus{border-color:var(--green-l)}
.sort-sel{
  padding:10px 14px;border:1px solid var(--border2);border-radius:8px;
  font-family:'Plus Jakarta Sans',sans-serif;font-size:0.88rem;
  background:var(--white);color:var(--ink);outline:none;cursor:pointer;
  transition:border-color 0.2s;
}
.sort-sel:focus{border-color:var(--green-l)}

/* ── FILTERS ── */
.filters{display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1.5rem}
.filter-btn{
  background:var(--white);border:1px solid var(--border2);
  color:var(--muted);padding:6px 14px;border-radius:20px;
  font-size:0.82rem;font-weight:500;cursor:pointer;
  font-family:'Plus Jakarta Sans',sans-serif;transition:all 0.2s;
}
.filter-btn.active,.filter-btn:hover{background:var(--ink);color:#fff;border-color:var(--ink)}

/* ── FEED HEADER ── */
.feed-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;flex-wrap:wrap;gap:0.5rem}
.feed-title{font-family:'Fraunces',serif;font-size:1.2rem;font-weight:600}
.feed-count{font-size:0.82rem;color:var(--muted)}

/* ── IDEA CARDS ── */
.ideas-feed{display:flex;flex-direction:column;gap:1rem}
.idea-card{
  background:var(--white);border:1px solid var(--border);
  border-radius:var(--r2);padding:1.4rem 1.5rem;
  box-shadow:var(--shadow);transition:all 0.22s;cursor:pointer;
  animation:fadeUp 0.35s ease both;
}
.idea-card:hover{transform:translateY(-2px);box-shadow:var(--shadow2);border-color:var(--border2)}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

.card-head{display:flex;gap:0.8rem;align-items:flex-start}
.vote-col{display:flex;flex-direction:column;align-items:center;gap:4px;flex-shrink:0}
.vote-up{
  width:34px;height:34px;border-radius:8px;
  border:1px solid var(--border2);background:none;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;font-size:0.9rem;color:var(--muted);
  transition:all 0.18s;font-family:'Plus Jakarta Sans',sans-serif;
}
.vote-up:hover{background:var(--green-bg);border-color:var(--green-l);color:var(--green)}
.vote-up.voted{background:var(--green-bg);border-color:var(--green-l);color:var(--green)}
.vote-num{font-size:0.9rem;font-weight:700;color:var(--ink);line-height:1}

.card-body{flex:1;min-width:0}
.card-tags{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:7px}
.tag{display:inline-block;font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;padding:3px 9px;border-radius:4px}
.tag-env{background:var(--green-bg);color:var(--green)}
.tag-edu{background:var(--blue-bg);color:var(--blue)}
.tag-health{background:var(--red-bg);color:var(--red)}
.tag-tech{background:var(--amber-bg);color:var(--amber)}
.tag-social{background:var(--purple-bg);color:var(--purple)}
.tag-food{background:var(--teal-bg);color:var(--teal)}
.tag-water{background:var(--blue-bg);color:var(--blue)}
.tag-new{background:#fff3cd;color:#856404;font-size:0.65rem}

.card-title{font-family:'Fraunces',serif;font-size:1.05rem;font-weight:600;margin-bottom:5px;line-height:1.3;color:var(--ink)}
.card-desc{font-size:0.86rem;color:var(--muted);line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}

.card-foot{display:flex;align-items:center;justify-content:space-between;margin-top:0.9rem;flex-wrap:wrap;gap:0.5rem}
.author-row{display:flex;align-items:center;gap:7px}
.avatar{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.6rem;font-weight:700;color:#fff;flex-shrink:0}
.author-name{font-size:0.8rem;color:var(--muted)}
.author-country{font-size:0.8rem;color:var(--muted)}
.card-meta{display:flex;gap:0.9rem;align-items:center}
.meta-chip{font-size:0.76rem;color:var(--muted);display:flex;align-items:center;gap:3px}

/* ── EMPTY / LOADING ── */
.empty{text-align:center;padding:3rem 1rem;color:var(--muted)}
.empty-icon{font-size:2.5rem;margin-bottom:0.75rem}
.empty p{font-size:0.95rem}
.load-more-btn{
  width:100%;margin-top:1.2rem;padding:11px;
  background:var(--white);border:1px solid var(--border2);border-radius:8px;
  font-family:'Plus Jakarta Sans',sans-serif;font-size:0.9rem;font-weight:500;
  color:var(--muted);cursor:pointer;transition:all 0.2s;
}
.load-more-btn:hover{background:var(--cream);color:var(--ink)}

/* ── SIDEBAR ── */
.sidebar{display:flex;flex-direction:column;gap:1.2rem}
.s-card{background:var(--white);border:1px solid var(--border);border-radius:var(--r2);padding:1.25rem;box-shadow:var(--shadow)}
.s-title{font-family:'Fraunces',serif;font-size:0.95rem;font-weight:600;margin-bottom:1rem;padding-bottom:0.65rem;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:7px}

/* ── FORM ── */
.form{display:flex;flex-direction:column;gap:0.7rem}
.f-label{font-size:0.74rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:0.4px;margin-bottom:3px;display:block}
.f-inp,.f-ta,.f-sel{
  width:100%;border:1px solid var(--border2);border-radius:7px;
  padding:8px 11px;font-family:'Plus Jakarta Sans',sans-serif;font-size:0.88rem;
  color:var(--ink);background:var(--cream);outline:none;transition:border-color 0.2s;
}
.f-inp:focus,.f-ta:focus,.f-sel:focus{border-color:var(--green-l);background:var(--white)}
.f-ta{resize:vertical;min-height:80px;max-height:200px}
.f-inp.error,.f-ta.error,.f-sel.error{border-color:var(--red)}
.char-count{font-size:0.7rem;color:var(--muted);text-align:right;margin-top:2px}
.submit-btn{
  background:var(--green);color:#fff;border:none;
  padding:10px 18px;border-radius:8px;font-family:'Plus Jakarta Sans',sans-serif;
  font-size:0.9rem;font-weight:600;cursor:pointer;transition:all 0.2s;
  display:flex;align-items:center;justify-content:center;gap:6px;
}
.submit-btn:hover{background:var(--green-l);transform:translateY(-1px)}
.submit-btn:disabled{opacity:0.6;cursor:not-allowed;transform:none}
.form-error{font-size:0.78rem;color:var(--red);margin-top:2px}

/* ── TRENDING ── */
.trend-list{display:flex;flex-direction:column;gap:0.55rem}
.trend-item{display:flex;align-items:center;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border);cursor:pointer;transition:color 0.2s}
.trend-item:last-child{border-bottom:none}
.trend-item:hover .trend-name{color:var(--green)}
.trend-name{font-size:0.86rem;color:var(--ink);transition:color 0.2s}
.trend-count{background:var(--green-bg);color:var(--green);font-size:0.72rem;font-weight:700;padding:2px 8px;border-radius:10px}

/* ── COUNTRIES ── */
.country-list{display:flex;flex-direction:column;gap:0.6rem}
.country-row{display:flex;align-items:center;gap:8px}
.c-flag{font-size:1rem;flex-shrink:0}
.c-name{font-size:0.8rem;flex:0 0 72px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.c-bar-bg{flex:1;height:5px;background:var(--green-bg);border-radius:3px;overflow:hidden}
.c-bar{height:100%;background:var(--green-l);border-radius:3px;transition:width 0.8s ease}
.c-num{font-size:0.72rem;color:var(--muted);flex:0 0 28px;text-align:right}

/* ── CATEGORIES LEGEND ── */
.cat-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.5rem}
.cat-item{display:flex;align-items:center;gap:6px;font-size:0.78rem;padding:5px 8px;border-radius:6px;cursor:pointer;transition:background 0.15s;color:var(--ink2)}
.cat-item:hover{background:var(--cream)}
.cat-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}

/* ── MODAL ── */
.overlay{
  display:none;position:fixed;inset:0;
  background:rgba(0,0,0,0.5);z-index:100;
  align-items:center;justify-content:center;padding:1rem;
  backdrop-filter:blur(2px);
}
.overlay.open{display:flex;animation:fadeIn 0.2s ease}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.modal{
  background:var(--white);border-radius:20px;
  padding:0;max-width:580px;width:100%;
  max-height:90vh;overflow-y:auto;
  position:relative;animation:slideUp 0.25s ease;
  box-shadow:0 20px 60px rgba(0,0,0,0.25);
}
@keyframes slideUp{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}
.modal-close{
  position:absolute;top:1rem;right:1rem;
  width:32px;height:32px;border-radius:50%;
  border:1px solid var(--border2);background:var(--cream);
  font-size:1rem;cursor:pointer;color:var(--muted);
  display:flex;align-items:center;justify-content:center;transition:all 0.15s;z-index:2;
}
.modal-close:hover{background:var(--border);color:var(--ink)}
.modal-hero{padding:2rem 2rem 1.25rem;border-bottom:1px solid var(--border)}
.modal-tags{margin-bottom:0.75rem;display:flex;gap:5px;flex-wrap:wrap}
.modal-title{font-family:'Fraunces',serif;font-size:1.5rem;font-weight:700;line-height:1.2;margin-bottom:0.75rem;letter-spacing:-0.5px}
.modal-desc{font-size:0.93rem;color:var(--muted);line-height:1.75}
.modal-body{padding:1.25rem 2rem}
.modal-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;margin-bottom:1.25rem}
.m-stat{background:var(--cream);border-radius:10px;padding:0.9rem;text-align:center}
.m-stat-n{font-family:'Fraunces',serif;font-size:1.3rem;font-weight:700;color:var(--green)}
.m-stat-l{font-size:0.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.4px;margin-top:2px}
.modal-author{display:flex;align-items:center;gap:10px;margin-bottom:1.25rem;padding:0.85rem;background:var(--cream);border-radius:10px}
.modal-author .avatar{width:36px;height:36px;font-size:0.8rem}
.modal-author-info{}
.modal-author-name{font-size:0.9rem;font-weight:600}
.modal-author-sub{font-size:0.78rem;color:var(--muted)}
.modal-actions{display:flex;gap:0.75rem;flex-wrap:wrap}
.modal-actions button{
  flex:1;min-width:120px;padding:10px 14px;border-radius:8px;
  font-family:'Plus Jakarta Sans',sans-serif;font-size:0.88rem;font-weight:600;
  cursor:pointer;border:1px solid var(--border2);background:var(--white);
  color:var(--ink);transition:all 0.18s;
}
.modal-actions button:hover{background:var(--cream)}
.modal-vote-btn{background:var(--green) !important;color:#fff !important;border-color:var(--green) !important}
.modal-vote-btn:hover{background:var(--green-l) !important}
.modal-vote-btn.voted-m{background:var(--green-bg) !important;color:var(--green) !important;border-color:var(--green-l) !important}
.modal-share-btn{}
.comments-section{margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid var(--border)}
.comments-title{font-size:0.85rem;font-weight:700;margin-bottom:0.75rem;color:var(--ink)}
.comment-box{display:flex;gap:8px;margin-bottom:0.75rem}
.comment-input{flex:1;border:1px solid var(--border2);border-radius:7px;padding:8px 11px;font-family:'Plus Jakarta Sans',sans-serif;font-size:0.83rem;color:var(--ink);background:var(--cream);outline:none;transition:border-color 0.2s}
.comment-input:focus{border-color:var(--green-l);background:var(--white)}
.comment-submit{background:var(--green);color:#fff;border:none;padding:8px 14px;border-radius:7px;font-family:'Plus Jakarta Sans',sans-serif;font-size:0.83rem;font-weight:600;cursor:pointer;transition:background 0.2s;white-space:nowrap}
.comment-submit:hover{background:var(--green-l)}
.comment-list{display:flex;flex-direction:column;gap:0.6rem}
.comment-item{background:var(--cream);border-radius:8px;padding:0.7rem 0.85rem}
.comment-meta{font-size:0.72rem;color:var(--muted);margin-bottom:3px}
.comment-text{font-size:0.83rem;color:var(--ink2)}

/* ── TOAST ── */
.toast{
  position:fixed;bottom:1.5rem;right:1.5rem;z-index:200;
  background:var(--ink);color:#fff;
  padding:0.8rem 1.2rem;border-radius:10px;
  font-size:0.88rem;font-weight:500;
  transform:translateY(80px);opacity:0;
  transition:all 0.3s cubic-bezier(0.34,1.56,0.64,1);
  max-width:300px;box-shadow:var(--shadow2);
  display:flex;align-items:center;gap:8px;
}
.toast.show{transform:translateY(0);opacity:1}
.toast.success{background:var(--green)}
.toast.error{background:var(--red)}

/* ── FOOTER ── */
footer{background:var(--ink);color:rgba(255,255,255,0.5);text-align:center;padding:1.5rem;font-size:0.8rem;margin-top:3rem}
footer span{color:var(--green-l)}

/* ── RESPONSIVE ── */
@media(max-width:600px){
  .hero{padding:3rem 1.2rem 2.5rem}
  .stat-item{padding:0.9rem 1.2rem}
  .page{padding:1.5rem 1rem}
  .modal-body,.modal-hero{padding:1.25rem}
  .modal-stats{grid-template-columns:repeat(3,1fr)}
  .modal-actions button{font-size:0.8rem;padding:9px 10px}
}
</style>
</head>
<body>

<!-- NAVBAR -->
<nav class="nav">
  <a class="logo" href="#" onclick="return false">
    <div class="logo-dot">🌍</div>
    IdeaSphere
  </a>
  <div class="nav-right">
    <button class="nav-link" onclick="scrollToFeed()">Explore</button>
    <button class="nav-link" onclick="showToast('About: IdeaSphere is a global community platform for sharing world-changing ideas.','')">About</button>
    <button class="nav-btn" onclick="scrollToForm()">+ Share Idea</button>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-inner">
    <div class="hero-pill">🌱 Open Platform &nbsp;·&nbsp; 87 Countries &nbsp;·&nbsp; Free Forever</div>
    <h1>Where <em>Community</em><br>Ideas Change the World</h1>
    <p class="hero-sub">A global space for students and citizens to share, vote, and grow ideas that make our world better — one community at a time.</p>
    <div class="hero-cta">
      <button class="btn-hero-p" onclick="scrollToForm()">Share Your Idea</button>
      <button class="btn-hero-s" onclick="scrollToFeed()">Explore Ideas ↓</button>
    </div>
  </div>
</section>

<!-- STATS -->
<div class="stats-bar" id="stats-bar">
  <div class="stat-item"><div class="stat-n" id="stat-total">0</div><div class="stat-l">Ideas Shared</div></div>
