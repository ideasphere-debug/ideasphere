  <p>Made with <span>♥</span> for community science students worldwide &nbsp;·&nbsp; IdeaSphere © 2025</p>
</footer>

<script>
// ══════════════════════════════════════════════════════════
//  DATA LAYER
// ══════════════════════════════════════════════════════════
const CAT_META = {
  environment:{ label:'Environment', emoji:'🌿', tagClass:'tag-env', color:'#1f6b43', dotColor:'#2e9460' },
  education:  { label:'Education',   emoji:'📚', tagClass:'tag-edu', color:'#1a5080', dotColor:'#3a8ac0' },
  health:     { label:'Health',      emoji:'❤️', tagClass:'tag-health',color:'#b83030',dotColor:'#d85050' },
  tech:       { label:'Technology',  emoji:'💻', tagClass:'tag-tech', color:'#9a6010', dotColor:'#c8901a' },
  social:     { label:'Social',      emoji:'🤝', tagClass:'tag-social',color:'#5a2d8a',dotColor:'#8050c0' },
  food:       { label:'Food & Agri', emoji:'🌾', tagClass:'tag-food', color:'#0d6e6e', dotColor:'#1a9898' },
};

const AVATAR_COLORS = ['#1f6b43','#1a5080','#b83030','#9a6010','#5a2d8a','#0d6e6e','#3a6b1f','#80301a'];

function getAvatarColor(name){ let h=0; for(let c of name||'?') h=(h*31+c.charCodeAt(0))&0xffff; return AVATAR_COLORS[h%AVATAR_COLORS.length]; }
function initials(name){ return (name||'?').split(' ').map(w=>w[0]||'').join('').substring(0,2).toUpperCase()||'??'; }
function timeAgo(ts){ const s=Math.floor((Date.now()-ts)/1000); if(s<60)return 'just now'; if(s<3600)return Math.floor(s/60)+'m ago'; if(s<86400)return Math.floor(s/3600)+'h ago'; if(s<604800)return Math.floor(s/86400)+'d ago'; return Math.floor(s/604800)+'w ago'; }
function esc(s){ const d=document.createElement('div'); d.textContent=s; return d.innerHTML; }

const DEFAULT_IDEAS = [
  { id:'d1', title:'Rainwater Harvesting Kits for Every School', desc:'Design low-cost, DIY rainwater collection kits that any school can install. Collected water is used for sanitation and small gardens, teaching students water conservation while solving a real, pressing problem in water-scarce regions.', category:'environment', author:'Priya Mehta', country:'India', flag:'🇮🇳', votes:342, comments:[ {name:'Ravi',text:'Brilliant idea! We need this in Rajasthan desperately.',ts:Date.now()-3600000},{name:'Amara',text:'Could easily scale to community centres too.',ts:Date.now()-1800000} ], reach:23, ts:Date.now()-172800000, voted:false },
  { id:'d2', title:'Offline Learning Pods for Remote Villages', desc:'Solar-powered offline devices preloaded with curated educational content in local languages, distributed to villages with no internet. Communities can update content via monthly USB drops — no connectivity required.', category:'education', author:'Amara Osei', country:'Ghana', flag:'🇬🇭', votes:289, comments:[{name:'Luisa',text:'This is exactly what rural Brazil needs too.',ts:Date.now()-7200000}], reach:41, ts:Date.now()-259200000, voted:false },
  { id:'d3', title:'Community Mental Health Street Murals', desc:'Commission local artists to paint public murals with mental health helpline numbers and calming messages in high-stress urban areas. Art that is beautiful, accessible, and life-saving — all at once.', category:'health', author:'Luisa Santos', country:'Brazil', flag:'🇧🇷', votes:215, comments:[{name:'Priya',text:'Art with purpose — this is so powerful.',ts:Date.now()-5400000}], reach:18, ts:Date.now()-345600000, voted:false },
  { id:'d4', title:'Open-Source Crop Disease Detection App', desc:'A free mobile app using AI to help small farmers identify crop diseases by photographing leaves. Works offline, gives treatment advice in local languages, and alerts nearby farmers of outbreaks automatically.', category:'tech', author:'Ravi Kumar', country:'India', flag:'🇮🇳', votes:198, comments:[{name:'Amara',text:'This could save millions of dollars in crop losses annually.',ts:Date.now()-10800000},{name:'Fatima',text:'Need this for wheat farms in Pakistan.',ts:Date.now()-9000000}], reach:29, ts:Date.now()-432000000, voted:false },
  { id:'d5', title:'Waste-to-Garden: Market Compost Program', desc:'Partner with municipalities to convert organic waste from local markets into free compost for low-income community gardens. Creates jobs, reduces landfill, and improves food access — three wins in one program.', category:'food', author:'Fatima Al-Rashid', country:'Nigeria', flag:'🇳🇬', votes:176, comments:[], reach:15, ts:Date.now()-518400000, voted:false },
  { id:'d6', title:'Neighbourhood Watch App for Women\'s Safety', desc:'A hyperlocal app that lets women mark safe routes, share real-time location with trusted contacts, and report unsafe areas. Community-driven safety mapping that works even on basic smartphones.', category:'social', author:'Anjali Sharma', country:'India', flag:'🇮🇳', votes:163, comments:[{name:'Luisa',text:'This would be transformative in São Paulo.',ts:Date.now()-14400000}], reach:32, ts:Date.now()-604800000, voted:false },
  { id:'d7', title:'Free Period Product Dispensers in Schools', desc:'Install free, accessible menstrual product dispensers in all school bathrooms. Partner with local NGOs for sustainable supply. Reduces dropout rates among girls and removes stigma around menstruation in schools.', category:'health', author:'Ngozi Adeyemi', country:'Nigeria', flag:'🇳🇬', votes:141, comments:[], reach:22, ts:Date.now()-691200000, voted:false },
  { id:'d8', title:'Local Seed Library Network', desc:'Establish community seed libraries in every district where farmers can borrow, grow, and return indigenous seeds. Preserves biodiversity, reduces seed costs for small farmers, and strengthens food sovereignty.', category:'food', author:'Miguel Torres', country:'Mexico', flag:'🇲🇽', votes:128, comments:[{name:'Ravi',text:'This is essentially what the Svalbard Vault does globally — we need it locally!',ts:Date.now()-21600000}], reach:19, ts:Date.now()-777600000, voted:false },
];

// ══════════════════════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════════════════════
let state = { ideas:[], filter:'all', search:'', sort:'newest', modalId:null, page:1, pageSize:6 };
const PER_PAGE = 6;

function loadState(){
  try {
    const saved = localStorage.getItem('ideasphere_v3');
    if(saved){ state.ideas = JSON.parse(saved); }
    else { state.ideas = JSON.parse(JSON.stringify(DEFAULT_IDEAS)); save(); }
  } catch(e) { state.ideas = JSON.parse(JSON.stringify(DEFAULT_IDEAS)); }
}
function save(){ try{ localStorage.setItem('ideasphere_v3', JSON.stringify(state.ideas)); }catch(e){} }
function getIdea(id){ return state.ideas.find(i=>i.id===id); }

// ══════════════════════════════════════════════════════════
//  FILTER / SORT
// ══════════════════════════════════════════════════════════
function getFiltered(){
  let list = [...state.ideas];
  if(state.filter !== 'all') list = list.filter(i=>i.category===state.filter);
  if(state.search.trim()){
    const q = state.search.trim().toLowerCase();
    list = list.filter(i=>
      i.title.toLowerCase().includes(q) ||
      i.desc.toLowerCase().includes(q) ||
      (i.author||'').toLowerCase().includes(q) ||
      (i.country||'').toLowerCase().includes(q) ||
      (CAT_META[i.category]||{}).label?.toLowerCase().includes(q)
    );
  }
  if(state.sort==='votes') list.sort((a,b)=>b.votes-a.votes);
  else if(state.sort==='comments') list.sort((a,b)=>b.comments.length-a.comments.length);
  else list.sort((a,b)=>b.ts-a.ts);
  return list;
}

function setFilter(cat){
  state.filter = cat;
  state.page = 1;
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.toggle('active', b.dataset.cat===cat));
  renderFeed();
}

function onSearch(){
  state.search = document.getElementById('search-input').value;
  state.page = 1;
  renderFeed();
}

// ══════════════════════════════════════════════════════════
//  RENDER FEED
// ══════════════════════════════════════════════════════════
function renderFeed(){
  state.sort = document.getElementById('sort-sel').value;
  const filtered = getFiltered();
  const total = filtered.length;
  const visible = filtered.slice(0, state.page * PER_PAGE);

  const el = document.getElementById('ideas-feed');
  const fc = document.getElementById('feed-count');
  const lm = document.getElementById('load-more-btn');
  const ft = document.getElementById('feed-title');

  const catLabel = state.filter==='all' ? 'Community Ideas' : (CAT_META[state.filter]?.label||'Ideas');
  ft.textContent = catLabel;
  fc.textContent = total===0 ? '' : `${total} idea${total!==1?'s':''}`;

  if(total===0){
    el.innerHTML = `<div class="empty"><div class="empty-icon">🔍</div><p>No ideas found. Try adjusting your search or filter.</p></div>`;
    lm.style.display='none';
    return;
  }

  el.innerHTML = visible.map((idea, i)=>{
    const cm = CAT_META[idea.category]||CAT_META.social;
    const av = getAvatarColor(idea.author||'?');
    const ini = initials(idea.author||'?');
    const isNew = (Date.now()-idea.ts)<86400000;
    return `
    <div class="idea-card" style="animation-delay:${Math.min(i,5)*0.06}s" onclick="openModal('${idea.id}')">
      <div class="card-head">
        <div class="vote-col" onclick="event.stopPropagation()">
          <button class="vote-up${idea.voted?' voted':''}" onclick="toggleVote('${idea.id}')" title="${idea.voted?'Remove vote':'Upvote this idea'}">▲</button>
          <span class="vote-num" id="vn-${idea.id}">${idea.votes}</span>
        </div>
        <div class="card-body">
          <div class="card-tags">
            <span class="tag ${cm.tagClass}">${cm.emoji} ${cm.label}</span>
            ${isNew?'<span class="tag tag-new">✨ New</span>':''}
          </div>
          <div class="card-title">${esc(idea.title)}</div>
          <div class="card-desc">${esc(idea.desc)}</div>
        </div>
      </div>
      <div class="card-foot">
        <div class="author-row">
          <div class="avatar" style="background:${av}">${ini}</div>
          <span class="author-name">${esc(idea.author||'Anonymous')}</span>
          ${idea.country?`<span class="author-country">${idea.flag||'🌍'} ${esc(idea.country)}</span>`:''}
        </div>
        <div class="card-meta">
          <span class="meta-chip">💬 ${idea.comments.length}</span>
          <span class="meta-chip">🌍 ${idea.reach}</span>
          <span class="meta-chip">🕐 ${timeAgo(idea.ts)}</span>
        </div>
      </div>
    </div>`;
  }).join('');

  lm.style.display = visible.length < total ? 'block' : 'none';
  updateStats();
}

function loadMore(){
  state.page++;
  renderFeed();
  // scroll to newly added
  setTimeout(()=>{
    const cards = document.querySelectorAll('.idea-card');
    if(cards.length) cards[cards.length-1].scrollIntoView({behavior:'smooth',block:'nearest'});
  },50);
}

// ══════════════════════════════════════════════════════════
//  VOTING
// ══════════════════════════════════════════════════════════
function toggleVote(id){
  const idea = getIdea(id);
  if(!idea) return;
  idea.voted = !idea.voted;
  idea.votes += idea.voted ? 1 : -1;
  save();
  // update card in-place without full re-render
  const btn = document.querySelector(`#ideas-feed .idea-card [onclick*="'${id}'"].vote-up`);
  const num = document.getElementById('vn-'+id);
  if(btn){ btn.classList.toggle('voted', idea.voted); btn.title = idea.voted?'Remove vote':'Upvote this idea'; }
  if(num) num.textContent = idea.votes;
  // update modal if open
  if(state.modalId===id){ document.getElementById('m-votes').textContent=idea.votes; syncModalVoteBtn(idea); }
  showToast(idea.voted ? '▲ Upvoted!' : 'Vote removed.', idea.voted?'success':'');
  updateStats();
}

// ══════════════════════════════════════════════════════════
//  SUBMIT IDEA
// ══════════════════════════════════════════════════════════
function updateCharCount(inputId, countId, max){
  const val = document.getElementById(inputId).value.length;
  document.getElementById(countId).textContent = `${val} / ${max}`;
}

function clearErrors(){ ['title','desc','cat'].forEach(f=>{ document.getElementById('err-'+f).textContent=''; document.getElementById('f-'+f).classList.remove('error'); }); }

function submitIdea(){
  clearErrors();
  const title   = document.getElementById('f-title').value.trim();
  const desc    = document.getElementById('f-desc').value.trim();
  const cat     = document.getElementById('f-cat').value;
  const author  = document.getElementById('f-author').value.trim() || 'Anonymous';
  const country = document.getElementById('f-country').value.trim();

  let valid = true;
  if(!title){ document.getElementById('err-title').textContent='Title is required.'; document.getElementById('f-title').classList.add('error'); valid=false; }
  if(title.length>100){ document.getElementById('err-title').textContent='Title too long (max 100 chars).'; document.getElementById('f-title').classList.add('error'); valid=false; }
  if(!desc){ document.getElementById('err-desc').textContent='Description is required.'; document.getElementById('f-desc').classList.add('error'); valid=false; }
  if(desc.length<20){ document.getElementById('err-desc').textContent='Please add more detail (min 20 characters).'; document.getElementById('f-desc').classList.add('error'); valid=false; }
  if(!cat){ document.getElementById('err-cat').textContent='Please select a category.'; document.getElementById('f-cat').classList.add('error'); valid=false; }
  if(!valid) return;

  const btn = document.getElementById('submit-btn');
  btn.disabled = true;
  btn.innerHTML = '<span>⏳</span> Submitting…';

  setTimeout(()=>{
    const flagMap={'india':'🇮🇳','brazil':'🇧🇷','nigeria':'🇳🇬','usa':'🇺🇸','ghana':'🇬🇭','pakistan':'🇵🇰','kenya':'🇰🇪','bangladesh':'🇧🇩','indonesia':'🇮🇩','mexico':'🇲🇽','ethiopia':'🇪🇹','egypt':'🇪🇬','china':'🇨🇳','uk':'🇬🇧','germany':'🇩🇪','france':'🇫🇷','japan':'🇯🇵'};
    const flag = country ? (flagMap[country.toLowerCase()]||'🌍') : '🌍';

    const newIdea = {
      id: 'u'+Date.now(),
      title, desc, category:cat, author, country, flag,
      votes:1, comments:[], reach:1,
      ts: Date.now(), voted:true
    };
    state.ideas.unshift(newIdea);
    save();

    // reset form
    ['f-title','f-desc','f-author','f-country'].forEach(id=>document.getElementById(id).value='');
    document.getElementById('f-cat').value='';
    ['tc-title','tc-desc'].forEach(id=>{ const el=document.getElementById(id); if(el) el.textContent=el.textContent.replace(/^\d+/,'0'); });

    btn.disabled = false;
    btn.innerHTML = '<span>🚀</span> Submit Idea';

    // reset filter & go to feed
    setFilter('all');
    document.getElementById('sort-sel').value = 'newest';
    state.sort='newest'; state.page=1; state.search='';
    document.getElementById('search-input').value='';
    renderFeed();
    renderSidebar();
    scrollToFeed();
    showToast('🎉 Your idea is live!','success');
  }, 600);
}

// ══════════════════════════════════════════════════════════
//  MODAL
// ══════════════════════════════════════════════════════════
function openModal(id){
  const idea = getIdea(id);
  if(!idea) return;
  state.modalId = id;
  const cm = CAT_META[idea.category]||CAT_META.social;
  const av = getAvatarColor(idea.author||'?');
  const ini = initials(idea.author||'?');

  document.getElementById('m-tags').innerHTML = `<span class="tag ${cm.tagClass}">${cm.emoji} ${cm.label}</span>`;
  document.getElementById('m-title').textContent = idea.title;
  document.getElementById('m-desc').textContent = idea.desc;
  document.getElementById('m-votes').textContent = idea.votes;
  document.getElementById('m-cmts').textContent = idea.comments.length;
  document.getElementById('m-reach').textContent = idea.reach;
  document.getElementById('m-avatar').style.background = av;
  document.getElementById('m-avatar').textContent = ini;
  document.getElementById('m-author-name').textContent = idea.author||'Anonymous';
  document.getElementById('m-author-sub').textContent = `${idea.flag||'🌍'} ${idea.country||'World'} · ${timeAgo(idea.ts)}`;
  document.getElementById('cmt-input').value = '';

  syncModalVoteBtn(idea);
  renderComments(idea);

  document.getElementById('overlay').classList.add('open');
  document.body.style.overflow='hidden';
}

function syncModalVoteBtn(idea){
  const btn = document.getElementById('m-vote-btn');
  btn.classList.toggle('voted-m', !!idea.voted);
  btn.textContent = idea.voted ? '✓ Voted' : '▲ Upvote';
}

function closeModal(){
  document.getElementById('overlay').classList.remove('open');
  document.body.style.overflow='';
  state.modalId = null;
}

function overlayClick(e){ if(e.target===document.getElementById('overlay')) closeModal(); }

function voteFromModal(){
  if(state.modalId) toggleVote(state.modalId);
}

function shareIdea(){
  const idea = getIdea(state.modalId);
  if(!idea) return;
  const text = `"${idea.title}" on IdeaSphere — Vote for this community idea!`;
  if(navigator.share){ navigator.share({title:'IdeaSphere Idea', text, url:window.location.href}).catch(()=>{}); }
  else {
    navigator.clipboard.writeText(text+' '+window.location.href).then(()=>showToast('🔗 Link copied!','')).catch(()=>showToast('🔗 Share: '+window.location.href,''));
  }
}

// ══════════════════════════════════════════════════════════
//  COMMENTS
// ══════════════════════════════════════════════════════════
function renderComments(idea){
  const list = document.getElementById('cmt-list');
  const title = document.getElementById('cmts-title');
  title.textContent = `Comments (${idea.comments.length})`;
  if(!idea.comments.length){
    list.innerHTML = '<div style="font-size:0.82rem;color:var(--muted);padding:0.5rem 0">No comments yet. Be the first!</div>';
    return;
  }
  list.innerHTML = [...idea.comments].reverse().map(c=>`
    <div class="comment-item">
      <div class="comment-meta">${esc(c.name||'Anonymous')} · ${timeAgo(c.ts)}</div>
      <div class="comment-text">${esc(c.text)}</div>
    </div>`).join('');
}

function addComment(){
  const inp = document.getElementById('cmt-input');
  const text = inp.value.trim();
  if(!text){ showToast('Please write a comment first.','error'); return; }
  if(!state.modalId) return;
  const idea = getIdea(state.modalId);
  if(!idea) return;
  const name = document.getElementById('f-author').value.trim()||'Anonymous';
  idea.comments.push({name, text, ts:Date.now()});
  save();
  inp.value='';
  document.getElementById('m-cmts').textContent = idea.comments.length;
  renderComments(idea);
  // update card comment count in-place
  renderFeed();
  showToast('💬 Comment posted!','success');
}

// ══════════════════════════════════════════════════════════
//  SIDEBAR
// ══════════════════════════════════════════════════════════
function renderSidebar(){
  renderTrending();
  renderCountries();
  renderCatGrid();
}

function renderTrending(){
  // Count most common words in titles (excluding common words)
  const stop = new Set(['a','an','the','for','and','or','of','in','to','is','are','with','that','this','it','on','at','by','as','be','we','our','all','can','any','how','its']);
  const freq = {};
  state.ideas.forEach(i=>{
    i.title.toLowerCase().split(/\W+/).filter(w=>w.length>3 && !stop.has(w)).forEach(w=>{ freq[w]=(freq[w]||0)+1; });
  });
  const top = Object.entries(freq).sort((a,b)=>b[1]-a[1]).slice(0,8);
  // Also add category-based topics
  const catCounts = {};
  state.ideas.forEach(i=>{ catCounts[i.category]=(catCounts[i.category]||0)+1; });

  const FIXED_TOPICS = [
    {name:'Clean Water Access',count:142},
    {name:'Rural Education',count:118},
    {name:'Plastic-Free Cities',count:97},
    {name:'Mental Health',count:83},
    {name:'Solar Energy',count:71},
    {name:'Food Security',count:state.ideas.filter(i=>i.category==='food').length*8+50},
    {name:'Women Safety',count:65},
    {name:'Zero Waste',count:58},
  ];

  document.getElementById('trend-list').innerHTML = FIXED_TOPICS.slice(0,7).map(t=>`
    <div class="trend-item" onclick="document.getElementById('search-input').value='${t.name.split(' ')[0]}';onSearch()">
      <span class="trend-name">${t.name}</span>
      <span class="trend-count">${t.count}</span>
    </div>`).join('');
}

function renderCountries(){
  const COUNTRIES = [
    {flag:'🇮🇳',name:'India',pct:85},
    {flag:'🇧🇷',name:'Brazil',pct:68},
    {flag:'🇳🇬',name:'Nigeria',pct:56},
    {flag:'🇺🇸',name:'USA',pct:49},
    {flag:'🇬🇭',name:'Ghana',pct:42},
    {flag:'🇵🇰',name:'Pakistan',pct:35},
  ];
  // Count user-submitted countries
  const userCounts = {};
  state.ideas.filter(i=>i.id.startsWith('u')).forEach(i=>{ if(i.country) userCounts[i.country]=(userCounts[i.country]||0)+1; });

  document.getElementById('country-list').innerHTML = COUNTRIES.map(c=>`
    <div class="country-row">
      <span class="c-flag">${c.flag}</span>
      <span class="c-name">${c.name}</span>
      <div class="c-bar-bg"><div class="c-bar" style="width:${c.pct}%"></div></div>
      <span class="c-num">${c.pct}</span>
    </div>`).join('');
}

function renderCatGrid(){
  document.getElementById('cat-grid').innerHTML = Object.entries(CAT_META).map(([key,cm])=>{
    const count = state.ideas.filter(i=>i.category===key).length;
    return `<div class="cat-item" onclick="setFilter('${key}')">
      <div class="cat-dot" style="background:${cm.dotColor}"></div>
      <span>${cm.emoji} ${cm.label} <span style="color:var(--muted);font-size:0.72rem">(${count})</span></span>
    </div>`;
  }).join('');
}

// ══════════════════════════════════════════════════════════
//  STATS
// ══════════════════════════════════════════════════════════
function updateStats(){
  const totalVotes = state.ideas.reduce((s,i)=>s+i.votes,0);
  document.getElementById('stat-total').textContent = state.ideas.length.toLocaleString();
  document.getElementById('stat-votes').textContent = totalVotes.toLocaleString();
}

// ══════════════════════════════════════════════════════════
//  TOAST
// ══════════════════════════════════════════════════════════
let toastTimer;
function showToast(msg, type=''){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (type?' '+type:'');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=>{ t.className='toast'; }, 3000);
}

// ══════════════════════════════════════════════════════════
//  SCROLL HELPERS
// ══════════════════════════════════════════════════════════
function scrollToFeed(){ document.getElementById('feed-col').scrollIntoView({behavior:'smooth',block:'start'}); }
function scrollToForm(){ document.getElementById('form-card').scrollIntoView({behavior:'smooth',block:'start'}); document.getElementById('f-title').focus(); }

// ══════════════════════════════════════════════════════════
//  KEYBOARD
// ══════════════════════════════════════════════════════════
document.addEventListener('keydown',e=>{ if(e.key==='Escape') closeModal(); });

// ══════════════════════════════════════════════════════════
//  INIT
// ══════════════════════════════════════════════════════════
loadState();
renderFeed();
renderSidebar();
updateStats();
</script>
